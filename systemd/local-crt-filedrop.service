[Unit]
Description=Local CRT FileDrop
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=alan
WorkingDirectory=/home/alan/dev/tranfersistem/local-crt-filedrop
EnvironmentFile=-/home/alan/dev/tranfersistem/local-crt-filedrop/.env
ExecStart=/home/alan/dev/tranfersistem/local-crt-filedrop/venv/bin/python -m app.main
Restart=on-failure
RestartSec=3

[Install]
WantedBy=multi-user.target
